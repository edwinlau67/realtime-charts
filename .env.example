# Copy this file to .env and fill in your API keys.
# .env is git-ignored — never commit it.

# ── Finnhub ──────────────────────────────────────────────
# Required when SOURCES includes "finnhub"
FINNHUB_API_KEY=

# ── Alpaca ───────────────────────────────────────────────
# Required when SOURCES includes "alpaca"
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ── Twelve Data ──────────────────────────────────────────
# Required when SOURCES includes "twelvedata"
TWELVE_DATA_API_KEY=

# ── Optional overrides ───────────────────────────────────
# PORT=4000
# TICK_MS=250
# SOURCES=simulated,binance,coinbase,kraken,yahoo
# FINNHUB_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,TSLA,META,INTC,SPY,QQQ
# ALPACA_SYMBOLS=
# TWELVE_DATA_SYMBOLS=
# BINANCE_PAIRS=
# COINBASE_PRODUCTS=
# KRAKEN_PAIRS=
# OKX_INSTRUMENTS=
# YAHOO_SYMBOLS=
# YAHOO_POLL_MS=3000
# STOOQ_SYMBOLS=
# STOOQ_POLL_MS=5000
