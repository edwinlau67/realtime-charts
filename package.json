{
  "name": "realtime-charts",
  "version": "1.0.0",
  "private": true,
  "description": "Realtime stock charts monitoring system. Tick-level WebSocket stream with OHLCV candles aggregated up to 1-minute resolution.",
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix client install",
    "dev:server": "npm --prefix server run dev",
    "dev:server:finnhub": "SOURCES=finnhub FINNHUB_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,TSLA,META,INTC,SPY,QQQ npm --prefix server run dev",
    "dev:server:alpaca": "SOURCES=alpaca npm --prefix server run dev",
    "dev:server:twelvedata": "SOURCES=twelvedata npm --prefix server run dev",
    "dev:server:okx": "SOURCES=okx npm --prefix server run dev",
    "dev:server:kraken": "SOURCES=kraken npm --prefix server run dev",
    "dev:server:binance": "SOURCES=binance npm --prefix server run dev",
    "dev:server:coinbase": "SOURCES=coinbase npm --prefix server run dev",
    "dev:server:yahoo": "SOURCES=yahoo npm --prefix server run dev",
    "dev:server:stooq": "SOURCES=stooq npm --prefix server run dev",
    "dev:server:simulated": "SOURCES=simulated npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build:client": "npm --prefix client run build",
    "verify": "bash ./scripts/verify.sh",
    "test:server": "npm --prefix server test",
    "test:client": "npm --prefix client test",
    "test": "npm run test:server && npm run test:client"
  }
}
